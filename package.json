{
  "name": "sentisense",
  "version": "0.1.1",
  "description": "Official JavaScript/TypeScript SDK for the SentiSense market intelligence API",
  "author": "SentiSense <support@sentisense.ai>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SentiSenseApp/sentisense-node.git"
  },
  "homepage": "https://sentisense.ai",
  "bugs": {
    "url": "https://github.com/SentiSenseApp/sentisense-node/issues"
  },
  "keywords": [
    "sentisense",
    "finance",
    "stocks",
    "market",
    "sentiment",
    "api",
    "sdk",
    "trading",
    "institutional",
    "13f"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
